#!/usr/bin/env bash
# install-git-hooks — wire the sdlc SDD/TDD soft gates into THIS repo.
#
# Run once per clone, from the repo root:
#   bash ${CLAUDE_PLUGIN_ROOT}/hooks/install-git-hooks
#
# Copies pre-commit + pre-push into the repo's .githooks/, generates
# .githooks/sdlc.env from .claude/sdlc.toml (or defaults), and points
# core.hooksPath at .githooks. Copying (not symlinking to the versioned plugin
# dir) keeps the wiring stable across plugin upgrades — the repo owns its hook
# copy; re-run this after an upgrade to refresh.

set -euo pipefail

SRC_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel)"
HOOKS_DIR="${REPO_ROOT}/.githooks"
TOML="${REPO_ROOT}/.claude/sdlc.toml"

mkdir -p "$HOOKS_DIR"
# Warn before clobbering a pre-existing, non-sdlc hook (another tool's, or a
# hand-written one) — silent overwrite would be data loss.
for h in pre-commit pre-push; do
  if [[ -e "${HOOKS_DIR}/${h}" && ! -L "${HOOKS_DIR}/${h}" ]] && ! grep -q "sdlc .* soft-gate" "${HOOKS_DIR}/${h}" 2>/dev/null; then
    echo "⚠️  ${HOOKS_DIR}/${h} already exists and isn't an sdlc hook — overwriting. Back it up if you need it." >&2
  fi
done
cp "${SRC_DIR}/pre-commit" "${SRC_DIR}/pre-push" "$HOOKS_DIR/"
chmod +x "${HOOKS_DIR}/pre-commit" "${HOOKS_DIR}/pre-push"

# Read the four soft-gate tunables from .claude/sdlc.toml (if present), else
# defaults. Minimal scalar/array parse — no TOML lib dependency.
_scalar() { # _scalar <key> <default>  — strips both " and ' TOML string quotes
  local v=""
  [[ -f "$TOML" ]] && v=$(grep -E "^[[:space:]]*$1[[:space:]]*=" "$TOML" 2>/dev/null | head -1 | sed -E "s/^[^=]*=[[:space:]]*//; s/[[:space:]]*#.*\$//; s/^\"//; s/\"\$//; s/^'//; s/'\$//") || true
  echo "${v:-$2}"
}
_array() { # _array <key> <default-space-separated>  — flattens ["a","b"] → "a b"
  local raw=""
  [[ -f "$TOML" ]] && raw=$(grep -E "^[[:space:]]*$1[[:space:]]*=" "$TOML" 2>/dev/null | head -1 | sed -E 's/^[^=]*=[[:space:]]*//; s/^\[//; s/\][[:space:]]*(#.*)?$//') || true
  if [[ -z "${raw// /}" ]]; then echo "$2"; return; fi
  echo "$raw" | tr ',' ' ' | sed -E 's/"//g; s/'\''//g' | xargs
}

{
  echo "# generated by install-git-hooks from .claude/sdlc.toml (or defaults). Re-run to refresh."
  echo "INVARIANT_PATHS=\"$(_array invariant_paths src)\""
  echo "SPEC_DOC=\"$(_scalar spec_doc SPEC.md)\""
  echo "CODE_GLOB=\"$(_scalar code_glob '*.py')\""
  echo "TEST_DIR=\"$(_scalar test_dir tests)\""
  # Default branch: configured value, else detect from origin/HEAD, else main.
  # `|| true` is load-bearing: under pipefail a missing origin makes the pipe
  # exit nonzero and `set -e` would abort the installer mid-write.
  # symbolic-ref (not rev-parse --abbrev-ref) — the latter echoes "HEAD" back on
  # a missing ref instead of failing to empty, defeating the `:-main` fallback.
  _db=$(_scalar default_branch "")
  if [[ -z "$_db" ]]; then
    _db=$(git -C "$REPO_ROOT" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@' || true)
  fi
  echo "DEFAULT_BRANCH=\"${_db:-main}\""
} > "${HOOKS_DIR}/sdlc.env"

git -C "$REPO_ROOT" config core.hooksPath .githooks

echo "✓ sdlc soft gates installed → core.hooksPath=.githooks"
echo "  pre-commit (SDD), pre-push (TDD); tunables in .githooks/sdlc.env"
echo "  $(cat "${HOOKS_DIR}/sdlc.env" | grep -vE '^#' | tr '\n' ' ')"
